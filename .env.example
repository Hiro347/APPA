# =========================================================================
# APPA (Analisa Pasar Pintar & Akurat) - Environment Variables Configuration
# Copy this file to '.env' and fill in your private API credentials.
# =========================================================================

# --- Hugging Face Inference Settings ---
# Model ID hosted on Hugging Face Hub (either base model or fine-tuned model adapter)
HF_MODEL_ID=Qwen/Qwen2.5-7B-Instruct

# Hugging Face Read Access Token (Create one at https://huggingface.co/settings/tokens)
# Leave blank to run the system in 'Mock LLM' offline mode for local testing
HF_API_TOKEN=your_huggingface_read_token_here

# --- Web Search Settings ---
# SerpAPI search token for real-time competitor pricing and trends (https://serpapi.com)
# Leave blank to use local jabar-specific market data (fallback_mock_jabar.json)
SEARCH_API_KEY=your_serpapi_key_here

# --- Local Databases (Defaults) ---
# Note: In Docker compose, backend will automatically resolve 'QDRANT_HOST=qdrant'
QDRANT_HOST=localhost
QDRANT_PORT=6333
DATABASE_URL=sqlite:///./data/appa.db
